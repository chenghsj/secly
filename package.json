{
  "name": "secly",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "bin": {
    "secly": "./bin/secly.mjs"
  },
  "scripts": {
    "build:formula": "node ./scripts/build-homebrew-formula.mjs",
    "build:tap": "node ./scripts/build-homebrew-tap.mjs",
    "build:release": "node ./scripts/build-release.mjs",
    "build:standalone": "node ./scripts/build-standalone.mjs",
    "postinstall": "node --import tsx ./src/cli/run-cli.ts install",
    "dev": "vite dev --port 3000",
    "ui": "tsx src/cli/run-cli.ts ui",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:homebrew": "node ./scripts/test-homebrew-formula.mjs",
    "lint": "eslint .",
    "format": "prettier --check .",
    "check": "prettier --check . && eslint .",
    "fix": "prettier --write . && eslint . --fix",
    "cli": "tsx src/cli/run-cli.ts",
    "setup-local": "bash ./scripts/setup-local.sh",
    "uninstall-local": "bash ./scripts/uninstall-local.sh",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource/outfit": "^5.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "esbuild": "^0.27.7",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
